<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dim720 · Panel General Factoring</title>
    <link rel="shortcut icon" href="assets/img/icono.ico" type="image/x-icon">
    <script src="assets/js/hyper-config2.js"></script>
    <!-- Bootstrap 5 CSS -->
    <link href="assets/css/app-dim.min.css" class="app-style" rel="stylesheet">
    <link href="assets/css/style-2.css" rel="stylesheet">
    <!-- MDI Icons -->
    <link rel="stylesheet" href="assets/css/icons.min.css">
    <!-- Google Fonts (Dim720) -->
    <link href="assets/css/fonts.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <!-- Custom CSS del Dim720 -->
    <style>
        /* Estilos adicionales para tablas, barras y elementos específicos del factoring */
        .table-custom { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
        .table-custom th, .table-custom td { padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border-color); }
        .table-custom th { text-align: left; font-weight: 600; color: var(--text-secondary); }
        .table-custom td.r, .table-custom th.r { text-align: right; }
        .mono { font-family: var(--font-mono); }
        .bar-track { background: var(--gray-200); border-radius: 20px; height: 6px; width: 100%; overflow: hidden; }
        .bar-fill { height: 100%; border-radius: 20px; background: var(--success); width: 0%; }
        .funnel { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem; }
        .seg { padding: 0.6rem 1rem; border-radius: 12px; display: flex; justify-content: space-between; font-weight: 500; color: white; }
        .seg .v { font-family: var(--font-mono); font-weight: 600; }
        .alerts { display: flex; flex-direction: column; gap: 0.6rem; }
        .alert { display: flex; align-items: center; gap: 0.75rem; background: rgba(0,0,0,0.02); padding: 0.6rem 0.9rem; border-radius: 10px; border: 1px solid var(--border-color); }
        .alert .tag { font-size: 0.65rem; font-weight: 600; padding: 2px 8px; border-radius: 20px; background: var(--gray-200); color: var(--gray-700); }
        .alert .tag.cob { background: #E0F2FE; color: #0369A1; }
        .alert .tag.rec { background: #D1FAE5; color: #065F46; }
        .alert .tag.ope { background: #FEF3C7; color: #92400E; }
        .alert .tag.pro { background: #EDE9FE; color: #5B21B6; }
        .alert .tag.rie { background: #FFE4E6; color: #BE123C; }
        .alert .tag.car { background: #E0E7FF; color: #3730A3; }
        .alert .txt { flex: 1; font-size: 0.8rem; }
        .alert .cnt { font-weight: 700; font-family: var(--font-mono); }
        .alert .cnt.r { color: var(--danger); }
        .alert .cnt.y { color: var(--warning); }
        .grid.g-8-4 { display: grid; grid-template-columns: 1.8fr 1fr; gap: 1.25rem; }
        .grid.g-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
        @media (max-width: 1000px) { .grid.g-8-4, .grid.g-3 { grid-template-columns: 1fr; } }
        .vtype { font-size: 0.6rem; font-weight: normal; background: var(--gray-100); padding: 2px 8px; border-radius: 20px; margin-left: 10px; color: var(--gray-600); }
        .hint { font-size: 0.7rem; color: var(--text-muted); margin-top: -0.2rem; margin-bottom: 0.75rem; }
        .chart-wrap canvas { max-height: 100%; width: 100%; }
        .kpi.warn .value { color: var(--warning); }
        .semaphore { display: inline-flex; gap: 4px; margin-left: 6px; }
        .light { width: 8px; height: 8px; border-radius: 8px; background: #ccc; }
        .light.g { background: var(--success); }
        .light.y { background: var(--warning); }
    </style>
  <link rel="stylesheet" href="assets/css/styles.css">
</head>
<body>
<div class="wrapper">
    <!-- ========== Topbar (idéntica Dim720) ========== -->
    <div class="rd-navbar context rd-navbar-original rd-navbar-fullwidth">
        <div class="navbar-container fixed-top">
            <div class="navbar-custom">
                <div class="topbar">
                    <div class="d-flex align-items-center gap-lg-1 gap-1">
                        <div class="logo-topbar">
                            <a class="logo-light"><span class="logo-lg"><img src="assets/img/logo.png" alt="logo"></span><span class="logo-sm"><img src="assets/img/logo-sm.png" alt="small logo"></span></a>
                            <a class="logo-dark"><span class="logo-lg"><img src="assets/img/logo-dark.png" alt="dark logo"></span><span class="logo-sm"><img src="assets/img/logo-dark-sm.png" alt="small logo"></span></a>
                        </div>
                        <button class="button-toggle-menu"><i class="mdi mdi-menu"></i></button>
